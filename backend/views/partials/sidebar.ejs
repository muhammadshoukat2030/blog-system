<script>
    function applySavedTheme() {
        if (localStorage.getItem('theme-mode') === 'light') {
            document.documentElement.classList.add('light-mode-active');
        }
    }
    function toggleGlobalTheme() {
        const isLight = document.documentElement.classList.toggle('light-mode-active');
        localStorage.setItem('theme-mode', isLight ? 'light' : 'dark');
    }
    applySavedTheme();
</script>

