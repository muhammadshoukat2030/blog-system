<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gateway Authentication Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#030712] text-gray-100 font-sans min-h-screen flex items-center justify-center p-6">

    <div class="w-full max-w-md bg-[#0b1329] border border-gray-800 p-8 rounded-3xl shadow-2xl block text-left">
        <header class="text-center mb-8">
            <div class="bg-blue-600 text-white font-black px-4 py-1.5 rounded-xl text-base tracking-widest inline-block shadow-md mb-4">DZ</div>
            <h1 class="text-2xl font-black text-white tracking-tight">Access Gate Control</h1>
            <p class="text-gray-500 text-xs mt-1 font-medium">Please enter secure credentials to manage active content nodes.</p>
        </header>

        <% if (error) { %>
            <div class="bg-red-950/40 border border-red-900/30 text-red-400 text-xs px-4 py-3 rounded-xl mb-6 font-medium text-center">
                <%= error %>
            </div>
        <% } %>

        <form action="/dashboard/login" method="POST" class="space-y-5">
            <div>
                <label class="block text-[11px] font-bold uppercase text-gray-400 tracking-wider mb-2">Username Username</label>
                <input type="text" name="username" required placeholder="admin" class="w-full bg-gray-900 border border-gray-800 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-blue-500 transition font-medium" />
            </div>
            <div>
                <label class="block text-[11px] font-bold uppercase text-gray-400 tracking-wider mb-2">Password Configuration</label>
                <input type="password" name="password" required placeholder="admin123" class="w-full bg-gray-900 border border-gray-800 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-blue-500 transition font-medium" />
            </div>
            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white text-xs uppercase tracking-wider font-black py-3.5 rounded-xl transition duration-150 shadow-lg shadow-blue-600/20 mt-2">
                Authorize Session Access
            </button>
        </form>
    </div>

</body>
</html>